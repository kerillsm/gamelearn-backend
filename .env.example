# Application
APP_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gamelearn

# Authentication
AUTH_JWT_SECRET=your-jwt-secret
AUTH_REFRESH_TOKEN_SECRET=your-refresh-token-secret
AUTH_DISCORD_CLIENT_ID=your-discord-client-id
AUTH_DISCORD_CLIENT_SECRET=your-discord-client-secret

# S3 / Storage
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_CDN_URL=https://cdn.example.com
S3_FOLDER_NAME=uploads

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (optional)
SENTRY_DSN=https://...@sentry.io/...

# Resend Email Service (optional)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
