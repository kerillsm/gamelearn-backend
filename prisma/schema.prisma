generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String          @id @default(uuid())
  email                   String          @unique 
  name                    String          
  picture                 String?         
  discordUsername         String?         
  slug                    String?         @unique
  role                    UserRole        @default(USER)
  termsAcceptedAt         DateTime?       @db.Timestamptz
  stripeConnectAccountId  String?
  stripeConnectStatus     StripeConnectStatus @default(NOT_STARTED)
  availabilityRules       AvailabilityRule[]
  availabilityExceptions  AvailabilityException[]
  timezone                String?

  createdAt DateTime        @db.Timestamptz @default(now())
  updatedAt DateTime        @db.Timestamptz @updatedAt

  authAccounts      AuthAccount[]
  mentorProfiles    MentorProfile[]
  mentorSessionPacks   SessionPackage[] @relation("mentorSessionPacks")
  applicantSessionPacks SessionPackage[] @relation("applicantSessionPacks")
  referralCode      ReferralCode?  @relation("ReferralCodeOwner")
  referredBy        Referral?      @relation("ReferredUser")
  agreements        Agreement[]
  mentorApplication MentorApplication?
  testimonialsGiven  Testimonial[]  @relation("UserTestimonialsGiven")
  testimonialsReceived Testimonial[] @relation("MentorTestimonialsReceived")
  ledgerAccount     LedgerAccount?
}

enum StripeConnectStatus {
  NOT_STARTED
  PENDING
  ACTIVE
  RESTRICTED
}

enum UserRole {
  USER
  MENTOR
  ADMIN
}

model AuthAccount {
  id                  String   @id @default(uuid())
  userId              String
  provider            String  
  providerAccountId   String
  email               String?

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

enum MentorGame {
  DOTA2
}

enum MentorProfileStatus {
  PENDING
  REJECTED
  ACTIVE
  DISABLED
}

model MentorProfile {
  id                String   @id @default(uuid())
  userId            String
  name              String
  shortDescription  String
  description       String
  imageUrl          String
  game              MentorGame
  tags              String[]
  price             Int
  gameRating        Float?
  videoUrl          String?
  rejectionReason   String?
  status            MentorProfileStatus @default(PENDING)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @db.Timestamptz @default(now())
  updatedAt     DateTime @db.Timestamptz @updatedAt

  @@unique([userId, status])
}

model AvailabilityRule {
  id               String   @id @default(uuid())
  mentorUserId     String
  rrule            String
  startTime        String
  endTime          String
  timezone         String

  mentorUser       User @relation(fields: [mentorUserId], references: [id], onDelete: Cascade)

  createdAt        DateTime @db.Timestamptz @default(now())
  updatedAt        DateTime @db.Timestamptz @updatedAt

  @@index([mentorUserId])
}

enum ExceptionType {
  AVAILABLE
  UNAVAILABLE
}

model AvailabilityException {
  id               String   @id @default(uuid())
  mentorUserId     String
  date             DateTime @db.Timestamptz
  type             ExceptionType
  startTime        String
  endTime          String
  timezone         String

  mentorUser       User @relation(fields: [mentorUserId], references: [id], onDelete: Cascade)

  createdAt        DateTime @db.Timestamptz @default(now())
  updatedAt        DateTime @db.Timestamptz @updatedAt

  @@index([mentorUserId])
}

enum SessionPackageType {
  VIBE_CHECK
  ONE_SESSION
  SESSIONS_PACK
}

enum SessionPackStatus {
  PENDING
  PAYED
  APPROVED
  REJECTED
  COMPLETED
  CANCELED
  CANCELED_BY_APPLICANT
  CANCELED_BY_MENTOR
}

model SessionPackage {
  id                      String    @id @default(uuid())
  type                    SessionPackageType
  status                  SessionPackStatus  @default(PENDING)
  duration                Int
  price                   Float
  mentorId                String
  applicantId             String
  stripeSessionPackageId  String?   @unique
  stripePaymentIntentId   String?
  venue                   String?
  rejectionReason         String?
  stripeRefundId          String?
  refundAmount            Float?
  refundedAt              DateTime? @db.Timestamptz
  cancellationReason      String?
  firstSessionStartAt     DateTime  @db.Timestamptz
  lastSessionEndAt        DateTime  @db.Timestamptz

  createdAt DateTime @db.Timestamptz(6) @default(now())
  updatedAt DateTime @db.Timestamptz(6) @updatedAt

  mentor    User     @relation("mentorSessionPacks", fields: [mentorId], references: [id], onDelete: Cascade)
  applicant User     @relation("applicantSessionPacks", fields: [applicantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  payment   Payment?

  @@index([mentorId])
  @@index([applicantId])
}

enum SessionStatus {
  PENDING
  PAYED
  APPROVED
  REJECTED
  COMPLETED
  CANCELED
}

model Session {
  id                    String   @id @default(uuid())
  sessionPackageId     String
  scheduledAt           DateTime @db.Timestamptz
  status                SessionStatus @default(PENDING)
  duration              Int

  sessionPackage SessionPackage @relation(fields: [sessionPackageId], references: [id], onDelete: Cascade)

  createdAt        DateTime @db.Timestamptz @default(now())
  updatedAt        DateTime @db.Timestamptz @updatedAt

  @@index([sessionPackageId])
}

model ReferralCode {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String   @unique
  user      User     @relation("ReferralCodeOwner", fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[]

  createdAt DateTime @db.Timestamptz @default(now())
}

model Referral {
  id             String   @id @default(uuid())
  referralCodeId String
  referredUserId String   @unique
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUser   User     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  paymentReferrals PaymentReferral[]

  createdAt      DateTime @db.Timestamptz @default(now())
}


enum AgreementType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
}

model Agreement {
  id         String        @id @default(uuid())
  userId     String
  type       AgreementType
  version    String
  ipAddress  String
  userAgent  String?
  acceptedAt DateTime      @db.Timestamptz @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum MentorApplicationStatus {
  PENDING
  REJECTED
  APPROVED
}

model MentorApplication {
  id          String   @id @default(uuid())
  userId      String   @unique

  name        String
  game        MentorGame
  rating      Float
  experiencePlaying String
  experienceTeaching String?
  socialMedia String?
  aboutYourself  String?
  contactInfo String
  steamProfile String

  status      MentorApplicationStatus @default(PENDING)

  rejectionReason String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model Testimonial {
  id           String   @id @default(uuid())
  userId       String
  mentorUserId String
  content      String
  rating       Int

  status       TestimonialStatus @default(PENDING)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserTestimonialsGiven")
  mentorUser   User     @relation(fields: [mentorUserId], references: [id], onDelete: Cascade, name: "MentorTestimonialsReceived")

  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt

  @@index([mentorUserId])
  @@unique([userId, mentorUserId])
}


enum PaymentStatus {
  PENDING
  SUCCEEDED
  REFUNDED
}

model Payment {
  id                       String   @id @default(uuid())

  sessionPackageId         String   @unique
  sessionPackage           SessionPackage @relation(fields: [sessionPackageId], references: [id])

  stripePaymentIntentId    String   @unique

  amountCents              Int
  currency                 String

  // commissions snapshot 
  platformCommissionPct    Int
  platformCommissionCents  Int

  mentorPayoutCents        Int

  referrals                PaymentReferral[]

  status                   PaymentStatus

  ledgerEntries            LedgerEntry[]

  createdAt                DateTime @default(now())
}

model PaymentReferral {
  id          String   @id @default(uuid())
  paymentId   String
  referralId  String
  amountCents Int

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

enum LedgerAccountType {
  USER
  PLATFORM
}

model LedgerAccount {
  id        String   @id @default(uuid())
  userId    String?   @unique
  type      LedgerAccountType


  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   LedgerEntry[]

  createdAt DateTime @db.Timestamptz @default(now())
  updatedAt DateTime @db.Timestamptz @updatedAt
}

enum LedgerStatus {
  PENDING
  RELEASED
  REVERSED
}

model LedgerEntry {
  id            String   @id @default(uuid())

  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id])

  accountId     String
  account       LedgerAccount @relation(fields: [accountId], references: [id])

  amountCents   Int   // + or -

  status        LedgerStatus

  stripeTransferId String?

  createdAt     DateTime @default(now())
}



